# ===========================================================================
#  skooltool environment
# ===========================================================================
# Most operational settings (Skool link/login, Zapier URLs, rate limits,
# auto-DM toggle, admin password) are now configured at RUNTIME from the
# in-app settings page (/) and stored in the data store — you do NOT need to
# put them here. The values below are infrastructure + first-run bootstrap.
# ---------------------------------------------------------------------------

# REQUIRED — secret used to encrypt the stored Skool password (>=16 chars).
# Generate one: openssl rand -hex 32
APP_SECRET=change-me-to-a-long-random-string

# REQUIRED on Vercel — shared secret the Vercel Cron calls present as a
# Bearer token. Generate: openssl rand -hex 32
CRON_SECRET=change-me-too

# ---------------------------------------------------------------------------
# Storage backend
# ---------------------------------------------------------------------------
# If these are set, skooltool uses Upstash Redis ("Vercel KV"). On Vercel,
# adding the Upstash Redis marketplace integration sets KV_REST_API_URL /
# KV_REST_API_TOKEN for you automatically — you usually don't set them by hand.
# Leave BOTH unset locally to use the data/state.json file store.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# First-run bootstrap defaults (optional). The settings page overrides these
# once you save. Handy for self-hosting without touching the UI.
# ---------------------------------------------------------------------------
# SKOOL_EMAIL=you@example.com
# SKOOL_PASSWORD=your-password
# SKOOL_COMMUNITY=https://www.skool.com/your-community
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/000000/abcdef/
# ZAPIER_EVENT_WEBHOOK_URL=
# AUTO_DM_ENABLED=false
# DM_MIN_DELAY_MS=8000
# DM_MAX_DELAY_MS=20000
# DM_MAX_PER_RUN=40
# DM_MAX_PER_DAY=150

# ---------------------------------------------------------------------------
# Self-hosted (long-running) options — ignored on Vercel
# ---------------------------------------------------------------------------
PORT=3000
DAILY_SYNC_CRON=0 9 * * *
TZ=Europe/Berlin
SYNC_ON_STARTUP=false
HEADLESS=true
SLOW_MO_MS=0

# Force the serverless Chromium build locally (normally auto-detected on Vercel)
# USE_SERVERLESS_CHROMIUM=false

# Soft time budgets (ms) so a serverless function doesn't time out.
# SCRAPE_BUDGET_MS=45000
# WORKER_BUDGET_MS=45000

# Skip Playwright's browser download where Chromium is provided another way.
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Point the local launcher at an existing Chrome/Chromium binary instead of
# Playwright's managed download (CI, sandboxes, or system Chrome).
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/google-chrome

LOG_LEVEL=info
