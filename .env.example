# ---------------------------------------------------------------------------
# Skool credentials (the account that ADMINS the community you operate)
# ---------------------------------------------------------------------------
SKOOL_EMAIL=you@example.com
SKOOL_PASSWORD=your-password

# The community "slug" as it appears in the URL: https://www.skool.com/<slug>
SKOOL_COMMUNITY=your-community-slug

# ---------------------------------------------------------------------------
# Zapier (or any) inbound webhook that receives the daily new-member payload
# ---------------------------------------------------------------------------
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/000000/abcdef/

# Optional: a separate webhook for per-event triggers (defaults to ZAPIER_WEBHOOK_URL)
ZAPIER_EVENT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------
# Cron expression for the daily sync. Default: 09:00 every day.
DAILY_SYNC_CRON=0 9 * * *
# IANA timezone the cron runs in.
TZ=Europe/Berlin
# Run a sync immediately on startup (true/false)
SYNC_ON_STARTUP=false

# ---------------------------------------------------------------------------
# Browser behaviour
# ---------------------------------------------------------------------------
# Set to false to watch the browser while debugging selectors.
HEADLESS=true
# Slow down Playwright actions (ms) to look more human / debug.
SLOW_MO_MS=0

# ---------------------------------------------------------------------------
# Rate limiting for DMs (be conservative — this drives a real UI)
# ---------------------------------------------------------------------------
DM_MIN_DELAY_MS=8000
DM_MAX_DELAY_MS=20000
DM_MAX_PER_RUN=40
DM_MAX_PER_DAY=150

# ---------------------------------------------------------------------------
# Control API
# ---------------------------------------------------------------------------
PORT=3000
# Shared secret required in the `x-api-key` header to call control endpoints.
API_KEY=change-me

# ---------------------------------------------------------------------------
# Auto-DM behaviour (rule engine)
# ---------------------------------------------------------------------------
# Master switch. If false, triggers can still fire webhooks but will NOT send DMs.
AUTO_DM_ENABLED=false

LOG_LEVEL=info
